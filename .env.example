# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=your_mongodb_connection_string

# Auth
ACCESS_TOKEN_SECRET=replace_me
REFRESH_TOKEN_SECRET=replace_me

# CORS / frontend
CLIENT_URL=http://localhost:5173
SITE_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=gbp
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/cart?canceled=true

# WhatsApp number customers should message for course access
COURSE_WHATSAPP_NUMBER=2348012345678

# Email (Resend) - used to email customers after successful Stripe payment
EMAIL_FROM="The Transformed Me Academy <no-reply@thetransformedmeacademy.com>"
RESEND_API_KEY=re_replace_me
